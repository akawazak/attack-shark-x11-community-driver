<?xml version="1.0" encoding="utf-8"?>

<Window caption="0,0,0,40" size="400,200">
	<VerticalLayout bkimage="skins/select_color_bg.png">
		<HorizontalLayout name="appbar" height="23" bkcolor="0xFFFF0000">
			<Label name="about_title" text="about_text" align="left" valign="vcenter" width="200" textpadding="10,0,0,0" textcolor="0xFFFFFFFF" resourcetext="true"/>
			<Control/>
			<Button name="exit" width="23" normalimage="res='skins/exit_1.png' dest='4,4,19,19'" hotimage="res='skins/exit_2.png' dest='4,4,19,19'" pushedimage="res='skins/exit_2.png' dest='4,4,19,19'" padding="0,0,5,0" cursor="hand"/>
		</HorizontalLayout>
		
		<HorizontalLayout height="25" padding="20,30,0,0">
			<Label text="lan_text" align="right" valign="vcenter" width="120" textpadding="10,0,0,0" textcolor="0xFFFFFFFF" resourcetext="true"/>
			<Combo name="combo_lan" width="140" style="combo_style" resourcetext="false" padding="10,0,0,0" dropbox="bordercolor=&quot;0xFFEA5205&quot; bordersize=&quot;1&quot; bkcolor=&quot;0xFF000000&quot;">
				<ListLabelElement text="简体中文" height="22" tooltip="" selected="true"/>
				<ListLabelElement text="English" height="22" tooltip=""/>
				<ListLabelElement text="Tiếng Việt" height="22" tooltip=""/>
			</Combo>  
		</HorizontalLayout>
		
		<HorizontalLayout height="21" padding="20,10,0,0">
			<Label text="start_open_text" align="right" valign="vcenter" width="120" textpadding="10,0,0,0" textcolor="0xFFFFFFFF" resourcetext="true"/>
			<CheckBox name="check_startup" text="on_text" width="100" height="23" style="checkbox_style" cursor="hand" textpadding="20,0,0,0" padding="10,0,0,0"/>
		</HorizontalLayout>
		
		<HorizontalLayout height="21" padding="20,10,0,0" visible="false">
			<Label text="window_feedback_text" align="right" valign="vcenter" width="120" textpadding="10,0,0,0" textcolor="0xFFFFFFFF" resourcetext="true"/>
			<CheckBox name="check_window_feedback" text="on_text" width="100" height="23" style="checkbox_style" cursor="hand" textpadding="20,0,0,0" padding="10,0,0,0"/>
		</HorizontalLayout>
		<HorizontalLayout height="20" padding="20,20,0,0">
			<Label text="version_text" align="right" valign="vcenter" width="120" textpadding="10,0,0,0" textcolor="0xFFFFFFFF" resourcetext="true"/>
			<Label name="version" height="20" textpadding="10,0,0,0" align="left" valign="vcenter" textcolor="0xFFFFFFFF"/>
		</HorizontalLayout>
	</VerticalLayout>
</Window>