{
	"name": "attack-shark-x11-driver",
	"version": "1.2.1",
	"description": "A TypeScript driver for the Attack Shark X11 gaming mouse, supporting Linux and other platforms via Node.js/Bun and USB HID.",
	"author": {
		"name": "dressedinblack5",
		"email": "leonvargas4991@gmail.com",
		"url": ""
	},
	"license": "MIT",
	"homepage": "https://github.com/dressedinblack5/attack-shark-x11-electron#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/dressedinblack5/attack-shark-x11-electron.git"
	},
	"bugs": {
		"url": "https://github.com/dressedinblack5/attack-shark-x11-electron/issues"
	},
	"keywords": [
		"attack-shark",
		"x11",
		"mouse",
		"driver",
		"linux",
		"usb",
		"hid",
		"typescript"
	],
	"main": "./out/main/index.js",
	"scripts": {
		"dev": "electron-vite dev",
		"build": "electron-vite build",
		"preview": "electron-vite preview",
		"package": "electron-vite build && electron-builder",
		"lint": "bunx eslint . --ext .ts --cache --cache-strategy content",
		"lint:fix": "bunx eslint . --ext .ts --fix --cache --cache-strategy content",
		"format": "bunx prettier --check . --cache --cache-strategy content",
		"format:fix": "bunx prettier --write . --cache --cache-strategy content",
		"typecheck": "electron-vite typecheck",
		"prepare": "husky"
	},
	"build": {
		"appId": "com.attackshark.driver",
		"productName": "Attack Shark X11 Driver",
		"artifactName": "attack-shark-x11-electron-${version}.${ext}",
		"directories": {
			"output": "dist"
		},
		"files": [
			"out/**/*",
			"package.json"
		],
		"linux": {
			"target": [
				"AppImage",
				"deb"
			],
			"category": "Settings",
			"icon": "assets/cs-mouse.svg"
		}
	},
	"lint-staged": {
		"*.{ts,js,json}": [
			"prettier --write",
			"eslint --fix"
		]
	},
	"dependencies": {
		"@electron-toolkit/preload": "^3.0.2",
		"@electron-toolkit/utils": "^4.0.0",
		"lucide-vue-next": "^1.0.0",
		"pinia": "^3.0.4",
		"pino": "10.3.1",
		"usb": "2.17.0",
		"vue": "^3.5.34",
		"vue-i18n": "^11.4.4"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@tailwindcss/vite": "^4.3.0",
		"@types/bun": "^1.3.14",
		"@types/node": "^25.9.1",
		"@vitejs/plugin-vue": "^6.0.7",
		"autoprefixer": "^10.5.0",
		"electron": "^28.0.0",
		"electron-builder": "^26.8.1",
		"electron-vite": "^5.0.0",
		"eslint": "^10.4.1",
		"eslint-config-prettier": "^10.1.8",
		"globals": "^17.6.0",
		"husky": "^9.1.7",
		"jiti": "^2.7.0",
		"lint-staged": "^16.4.0",
		"postcss": "^8.5.15",
		"prettier": "3.8.1",
		"tailwindcss": "^4.3.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.60.0",
		"vite": "^7.3.3"
	}
}
