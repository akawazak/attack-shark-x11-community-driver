{
	"name": "attack-shark-x11-driver",
	"version": "1.4.4",
	"description": "A TypeScript driver for the Attack Shark X11 gaming mouse, supporting Linux and other platforms via Node.js/Bun and USB HID.",
	"desktopName": "attack-shark-x11-electron",
	"author": {
		"name": "akawazak",
		"url": "https://github.com/akawazak"
	},
	"contributors": [
		{
			"name": "dressedinblack5",
			"url": "https://github.com/dressedinblack5"
		},
		{
			"name": "HarukaYamamoto0",
			"url": "https://github.com/HarukaYamamoto0"
		},
		{
			"name": "xb-bx",
			"url": "https://github.com/xb-bx"
		}
	],
	"license": "MIT",
	"homepage": "https://github.com/akawazak/attack-shark-x11-community-driver#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/akawazak/attack-shark-x11-community-driver.git"
	},
	"bugs": {
		"url": "https://github.com/akawazak/attack-shark-x11-community-driver/issues"
	},
	"keywords": [
		"attack-shark",
		"x11",
		"mouse",
		"driver",
		"linux",
		"usb",
		"hid",
		"typescript"
	],
	"main": "./out/main/index.js",
	"scripts": {
		"dev": "npm run copy-driver-inf && electron-vite dev",
		"build": "npm run copy-driver-inf && electron-vite build",
		"preview": "electron-vite preview",
		"package": "npm run copy-driver-inf && electron-vite build && electron-builder",
		"copy-driver-inf": "node scripts/copy-driver-inf.cjs",
		"lint": "bunx eslint . --ext .ts --cache --cache-strategy content",
		"lint:fix": "bunx eslint . --ext .ts --fix --cache --cache-strategy content",
		"format": "bunx prettier --check . --cache --cache-strategy content",
		"format:fix": "bunx prettier --write . --cache --cache-strategy content",
		"typecheck": "tsc --noEmit",
		"postinstall": "node node_modules/electron/install.js",
		"prepare": "husky",
		"test": "bun test"
	},
	"build": {
		"appId": "com.attackshark.driver",
		"productName": "Attack Shark X11 Driver",
		"artifactName": "attack-shark-x11-electron-${version}.${ext}",
		"directories": {
			"output": "dist"
		},
		"publish": [
			{
				"provider": "github",
				"owner": "akawazak",
				"repo": "attack-shark-x11-community-driver"
			}
		],
		"files": [
			"out/**/*",
			"package.json",
			"drivers/**/*",
			"!node_modules/usb/target/**/*",
			"!node_modules/node-hid/build/Release/**/*.iobj",
			"!node_modules/node-hid/build/Release/**/*.ipdb",
			"!node_modules/node-hid/build/Release/**/*.lib",
			"!node_modules/node-hid/build/Release/**/*.pdb",
			"!node_modules/node-hid/build/Release/**/*.exp"
		],
		"extraResources": [
			{
				"from": "drivers",
				"to": "drivers",
				"filter": [
					"**/*.inf"
				]
			}
		],
		"nodeGypRebuild": false,
		"nativeRebuilder": "legacy",
		"linux": {
			"target": [
				"AppImage",
				"deb"
			],
			"category": "Settings",
			"icon": "assets/cs-mouse.svg",
			"syncDesktopName": true
		},
		"win": {
			"target": [
				{
					"target": "nsis",
					"arch": [
						"x64"
					]
				},
				{
					"target": "portable",
					"arch": [
						"x64"
					]
				}
			],
			"icon": "assets/attack-shark-x11-logo-2026.png"
		},
		"nsis": {
			"artifactName": "attack-shark-x11-electron-${version}-setup.${ext}",
			"oneClick": false,
			"allowToChangeInstallationDirectory": true,
			"createDesktopShortcut": true,
			"createStartMenuShortcut": true,
			"shortcutName": "Attack Shark X11 Driver"
		},
		"portable": {
			"artifactName": "attack-shark-x11-electron-${version}-portable.${ext}"
		}
	},
	"lint-staged": {
		"*.{ts,js,json}": [
			"prettier --write",
			"eslint --fix"
		]
	},
	"dependencies": {
		"@electron-toolkit/utils": "^4.0.0",
		"electron-updater": "^6.8.9",
		"lucide-vue-next": "^1.0.0",
		"node-hid": "^3.3.0",
		"usb": "github:dressedinblack5/node-usb-rs",
		"vue": "^3.5.38",
		"vue-i18n": "^11.4.5"
	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"@tailwindcss/vite": "^4.3.1",
		"@types/bun": "^1.3.14",
		"@types/node": "^25.9.3",
		"@vitejs/plugin-vue": "^6.0.7",
		"electron": "^42.4.0",
		"electron-builder": "^26.15.3",
		"electron-vite": "^5.0.0",
		"eslint": "^10.5.0",
		"eslint-config-prettier": "^10.1.8",
		"globals": "^17.6.0",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.7",
		"prettier": "3.8.4",
		"tailwindcss": "^4.3.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.61.0",
		"vite": "^8.0.16"
	},
	"trustedDependencies": [
		"usb"
	]
}
